{
  "version": 2,
  "buildCommand": "bash build.sh",
  "installCommand": "pip install -r requirements.txt",
  "framework": null,
  "builds": [
    {
      "src": "shareBear/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "shareBear/wsgi.py"
    }
  ]
}
